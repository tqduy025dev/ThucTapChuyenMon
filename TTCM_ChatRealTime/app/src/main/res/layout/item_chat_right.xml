<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:padding="2dp"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">


        <RelativeLayout
            android:id="@+id/relateLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="65dp"
            android:layout_marginEnd="4dp"
            android:layout_alignParentEnd="true"
            android:background="@drawable/background_chat_right">

            <TextView
                android:id="@+id/txtItem_chat_messageContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="8dp"
                android:textColor="@color/black"
                android:text="Hello"
                android:textSize="15sp" />
            <ImageView
                android:id="@+id/imgItem_chat_message"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_alignParentStart="true"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="8dp"
                android:visibility="gone"
                android:padding="5dp"/>
            <TextView
                android:id="@+id/txtItem_chat_time"
                android:layout_below="@+id/txtItem_chat_messageContent"
                android:layout_width="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textSize="10sp"
                android:paddingBottom="8dp"
                android:textColor="@color/black"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtItem_chat_timeImg"
                android:layout_below="@+id/imgItem_chat_message"
                android:layout_width="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textSize="10sp"
                android:paddingBottom="8dp"
                android:textColor="@color/black"
                android:layout_height="wrap_content"/>
        </RelativeLayout>



    <TextView
        android:id="@+id/txtItem_chat_seen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/relateLayout"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="3dp"
        android:layout_marginEnd="7dp"/>

</RelativeLayout>