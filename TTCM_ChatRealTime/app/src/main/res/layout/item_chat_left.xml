<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:padding="2dp"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="65dp"
        android:layout_alignParentStart="true">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/imgItem_chat_avatar"
            android:layout_width="32sp"
            android:layout_height="32sp"
            android:layout_gravity="center" />

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_alignParentEnd="true"
            android:background="@drawable/background_chat_left">

            <TextView
                android:id="@+id/txtItem_chat_messageContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="8dp"
                android:textColor="@color/black"
                android:text="Hello"
                android:textSize="15sp" />
            <TextView
                android:id="@+id/txtItem_chat_time"
                android:layout_below="@+id/txtItem_chat_messageContent"
                android:layout_width="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textSize="10sp"
                android:paddingBottom="8dp"
                android:textColor="@color/black"
                android:layout_height="wrap_content"/>
        </RelativeLayout>


    </LinearLayout>


</RelativeLayout>